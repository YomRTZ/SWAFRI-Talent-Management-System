# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/talent_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=talent_db
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Secrets
JWT_SECRET=your_super_secret_key_here
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=1d